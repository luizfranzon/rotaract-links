---
const { title, description, url, cover } = Astro.props;

const optimizedCover = cover
  ? `${cover}${cover.includes("?") ? "&" : "?"}width=288&height=230&fit=crop&auto=format,compress`
  : null;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Abrir ${title} em nova aba`}
  class="pop-in-card card-3d group block overflow-hidden rounded-(--radius-card) bg-(--surface) transition duration-200 hover:bg-(--surface-hover) focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--brand)">
  <div class="flex h-28.75 items-stretch">
    <div class="min-w-0 grow p-4">
      <h3 class="truncate text-sm font-bold leading-5 text-(--text-primary)">
        {title}
      </h3>
      <p class="mt-1 line-clamp-2 text-xs leading-5 text-(--text-secondary)">
        {description ?? "Confira os detalhes deste link oficial"}
      </p>
    </div>
    {
      cover && (
        <div class="w-36 shrink-0 overflow-hidden border-l border-(--border) bg-transparent">
          <img
            src={optimizedCover}
            alt={`Capa de ${title}`}
            loading="lazy"
            class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
          />
        </div>
      )
    }
  </div>
</a>

<style>
  .card-3d {
    position: relative;
    isolation: isolate;
    box-shadow: 3px 4px 0 #d304c7;
    border: 2px solid var(--border);
  }
  .card-3d:active {
    transform: translateY(2px);
    box-shadow: 2px 2px 0 #d304c7;
  }
</style>
