---
import LinkCard from "../components/LinkCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLinks } from "../lib/hygraph";

const pageTitle = "Links";
const pageDescription =
  "Acesse os links oficiais do Rotaract Club de Indaiatuba: redes sociais, campanhas e canais institucionais.";

const links = await getLinks();

const socialDomains = [
  "instagram.com",
  "facebook.com",
  "linkedin.com",
  "youtube.com",
  "x.com",
  "twitter.com",
  "tiktok.com",
];

const sameAs = links
  .map((link) => {
    try {
      return new URL(link.url);
    } catch {
      return null;
    }
  })
  .filter((link): link is URL => {
    if (!link) {
      return false;
    }

    return socialDomains.some((domain) => link.hostname.includes(domain));
  })
  .map((link) => link.toString());

const canonical = new URL(Astro.url.pathname, Astro.site ?? new URL(Astro.url.origin)).toString();
const siteBase = Astro.site ?? new URL(Astro.url.origin);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${canonical}#organization`,
      name: "Rotaract Club de Indaiatuba",
      url: canonical,
      logo: new URL("/logo.jpg", siteBase).toString(),
      sameAs,
    },
    {
      "@type": "WebSite",
      "@id": `${canonical}#website`,
      name: "Rotaract Indaiatuba",
      url: canonical,
      inLanguage: "pt-BR",
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      name: `${pageTitle} | Rotaract Indaiatuba`,
      url: canonical,
      description: pageDescription,
      isPartOf: {
        "@id": `${canonical}#website`,
      },
      about: {
        "@id": `${canonical}#organization`,
      },
      inLanguage: "pt-BR",
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} ogImage="/logo.jpg">
  <section class="mb-7 text-center">
    <div class="mx-auto mb-4 h-24 w-24 overflow-hidden rounded-full border border-(--border) bg-transparent">
      <img
        src="/logo.jpg"
        alt="Logo Rotaract"
        loading="eager"
        class="block h-full w-full object-cover object-center"
      />
    </div>
    <h1 class="text-3xl font-extrabold tracking-tight text-(--text-primary)">
      Rotaract Indaiatuba
    </h1>
    <p class="mx-auto mt-2 max-w-md text-sm text-(--text-secondary)">
      Encontre aqui os canais oficiais, campanhas e principais links do Rotaract Club de Indaiatuba.
    </p>
  </section>

  <section class="space-y-3">
    <h2 class="sr-only">Lista de links oficiais</h2>
    {
      links.map((link) => (
        <LinkCard
          title={link.title}
          description={link.description}
          url={link.url}
          cover={link.cover?.url}
        />
      ))
    }
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
</BaseLayout>
