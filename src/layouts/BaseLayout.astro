---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Links oficiais do Rotaract Club de Indaiatuba.",
  ogImage = "/logo.jpg",
  canonicalUrl,
  noindex = false,
} = Astro.props as Props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const ogImageWidth = 1024;
const ogImageHeight = 1024;
const robotsContent = noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large";
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo.jpg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preload" href="/fonts/Manrope-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Manrope-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ececec" />
    <meta name="author" content="Rotaract Club de Indaiatuba" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonical} />

    <meta property="og:locale" content="pt_BR" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Rotaract Indaiatuba" />
    <meta property="og:title" content={`${title} | Rotaract Indaiatuba`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:alt" content="Logo do Rotaract Club de Indaiatuba" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Rotaract Indaiatuba`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Logo do Rotaract Club de Indaiatuba" />

    <title>{title} | Rotaract Indaiatuba</title>
  </head>
  <body>
    <main class="mx-auto w-full max-w-xl px-4 py-10 sm:py-14">
      <slot />
    </main>
    <script is:inline>
      const addManifestLink = () => {
        if (document.querySelector('link[rel="manifest"]')) return;
        const manifest = document.createElement("link");
        manifest.rel = "manifest";
        manifest.href = "/site.webmanifest";
        document.head.appendChild(manifest);
      };

      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(addManifestLink, { timeout: 2000 });
      } else {
        window.addEventListener("load", addManifestLink, { once: true });
      }
    </script>
  </body>
</html>
